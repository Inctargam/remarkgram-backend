{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "apps/api-gateway/src",
  "compilerOptions": {
    "deleteOutDir": true,
    "webpack": false,
    "tsConfigPath": "apps/api-gateway/tsconfig.app.json",
    "assets": ["**/*.proto"],
    "watchAssets": true
  },
  "monorepo": true,
  "root": "apps/api-gateway",
  "projects": {
    "api-gateway": {
      "type": "application",
      "root": "apps/api-gateway",
      "entryFile": "main",
      "sourceRoot": "apps/api-gateway/src",
      "compilerOptions": {
        "tsConfigPath": "apps/api-gateway/tsconfig.app.json",
        "assets": [
          {
            "include": "../../../libs/contracts/files-grpc/src/proto/*.proto",
            "outDir": "dist/apps/api-gateway/libs/contracts/files-grpc"
          },
          {
            "include": "../../../libs/contracts/user-accounts-grpc/src/proto/*.proto",
            "outDir": "dist/apps/api-gateway/libs/contracts/user-accounts-grpc"
          }
        ]
      }
    },
    "config": {
      "type": "library",
      "root": "libs/config",
      "entryFile": "index",
      "sourceRoot": "libs/config/src",
      "compilerOptions": {
        "tsConfigPath": "libs/config/tsconfig.lib.json"
      }
    },
    "files": {
      "type": "application",
      "root": "apps/files",
      "entryFile": "main",
      "sourceRoot": "apps/files/src",
      "compilerOptions": {
        "tsConfigPath": "apps/files/tsconfig.app.json",
        "assets": [
          {
            "include": "../../../libs/contracts/files-grpc/src/proto/*.proto",
            "outDir": "dist/apps/files/libs/contracts/files-grpc"
          }
        ]
      }
    },
    "files-grpc": {
      "type": "library",
      "root": "libs/contracts/files-grpc",
      "entryFile": "index",
      "sourceRoot": "libs/contracts/files-grpc/src",
      "compilerOptions": {
        "tsConfigPath": "libs/contracts/files-grpc/tsconfig.lib.json"
      }
    },
    "user-accounts-grpc": {
      "type": "library",
      "root": "libs/contracts/user-accounts-grpc",
      "entryFile": "index",
      "sourceRoot": "libs/contracts/user-accounts-grpc/src",
      "compilerOptions": {
        "tsConfigPath": "libs/contracts/user-accounts-grpc/tsconfig.lib.json"
      }
    },
    "payments": {
      "type": "application",
      "root": "apps/payments",
      "entryFile": "main",
      "sourceRoot": "apps/payments/src",
      "compilerOptions": {
        "tsConfigPath": "apps/payments/tsconfig.app.json"
      }
    },
    "posts": {
      "type": "application",
      "root": "apps/posts",
      "entryFile": "main",
      "sourceRoot": "apps/posts/src",
      "compilerOptions": {
        "tsConfigPath": "apps/posts/tsconfig.app.json"
      }
    },
    "user-accounts": {
      "type": "application",
      "root": "apps/user-accounts",
      "entryFile": "main",
      "sourceRoot": "apps/user-accounts/src",
      "compilerOptions": {
        "tsConfigPath": "apps/user-accounts/tsconfig.app.json",
        "assets": [
          {
            "include": "../../../libs/contracts/user-accounts-grpc/src/proto/*.proto",
            "outDir": "dist/apps/user-accounts/libs/contracts/user-accounts-grpc"
          }
        ]
      }
    }
  }
}
