generator client {
  provider = "prisma-client"
  output   = "../src/database/generated"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique @db.VarChar
  email     String   @unique @db.VarChar
  hash      String   @db.VarChar
  createdAt DateTime @db.Timestamptz

  isConfirmed            Boolean
  confirmationCode       String?   @db.VarChar
  confirmationExpiration DateTime? @db.Timestamptz

  /// @deprecated Use `passwordResetTokens` instead.
  passwordRecoveryCode       String?   @db.VarChar
  passwordRecoveryExpiration DateTime? @db.Timestamptz

  passwordResetTokens PasswordResetToken[]
  passwordChangedAt   DateTime?            @db.Timestamptz

  deletedAt DateTime? @db.Timestamptz

  sessions DeviceSession[]

  @@map("users")
}

model DeviceSession {
  id     String @id @db.Uuid
  userId Int

  deviceName String @db.VarChar
  ip         String @db.VarChar
  jti        String @db.VarChar

  lastActiveAt DateTime @db.Timestamptz
  expiresAt    DateTime @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([userId])
  @@map("device_sessions")
}

model PasswordResetToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    Int

  tokenHash String    @unique @db.VarChar
  createdAt DateTime  @default(now()) @db.Timestamptz
  expiresAt DateTime  @db.Timestamptz
  usedAt    DateTime? @db.Timestamptz
  revokedAt DateTime? @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([userId])
  @@map("password_reset_tokens")
}
