generator client {
  provider        = "prisma-client"
  output          = "../src/database/generated"
  previewFeatures = ["partialIndexes"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @db.VarChar
  email     String   @db.VarChar
  hash      String?  @db.VarChar
  createdAt DateTime @db.Timestamptz

  isConfirmed            Boolean
  confirmationCode       String?   @db.VarChar
  confirmationExpiration DateTime? @db.Timestamptz

  passwordResetTokens PasswordResetToken[]
  passwordChangedAt   DateTime?            @db.Timestamptz

  deletedAt DateTime? @db.Timestamptz

  sessions DeviceSession[]

  providers AuthIdentity[]

  @@unique([username], where: {deletedAt: null})
  @@unique([email], where: {deletedAt: null})

  @@map("users")
}

enum RevokedReason {
  USER_LOGOUT
  LOGOUT_ALL
  PASSWORD_CHANGED
  USER_LOCKED
  ADMIN_ACTION
  TOKEN_REUSE_DETECTED
}

model DeviceSession {
  id     String @id @db.Uuid
  userId Int

  deviceName String @db.VarChar
  ip         String @db.VarChar
  jti        String @db.VarChar

  lastActiveAt DateTime @db.Timestamptz
  expiresAt    DateTime @db.Timestamptz

  revokedAt     DateTime?      @db.Timestamptz
  revokedReason RevokedReason?

  user User @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([userId])
  @@map("device_sessions")
}

model PasswordResetToken {
  id     String @id @default(uuid()) @db.Uuid
  userId Int

  tokenHash String    @unique @db.VarChar
  createdAt DateTime  @default(now()) @db.Timestamptz
  expiresAt DateTime  @db.Timestamptz
  usedAt    DateTime? @db.Timestamptz
  revokedAt DateTime? @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([userId])
  @@map("password_reset_tokens")
}

enum AuthProvider {
  github
  google
}

model AuthIdentity {
  id     String @id @default(uuid()) @db.Uuid
  userId Int // relation scalar field (foreign key)

  provider              AuthProvider
  providerSubject       String       @db.VarChar
  providerEmail         String?      @db.VarChar
  providerEmailVerified Boolean      @db.Boolean

  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz

  username  String? @db.VarChar
  avatarUrl String? @db.VarChar

  user User @relation(fields: [userId], references: [id])

  @@unique([provider, providerSubject])
  @@unique([userId, provider])
  @@index([userId])
  @@map("auth_identities")
}
