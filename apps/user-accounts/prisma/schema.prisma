generator client {
  provider        = "prisma-client"
  output          = "../src/database/generated"
  previewFeatures = ["partialIndexes"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @db.VarChar
  email     String   @db.VarChar
  hash      String   @db.VarChar
  createdAt DateTime @db.Timestamptz

  isConfirmed            Boolean
  confirmationCode       String?   @db.VarChar
  confirmationExpiration DateTime? @db.Timestamptz

  passwordRecoveryCode       String?   @db.VarChar
  passwordRecoveryExpiration DateTime? @db.Timestamptz

  deletedAt DateTime? @db.Timestamptz

  sessions DeviceSession[]

  @@unique([username], where: { deletedAt: null })
  @@unique([email], where: { deletedAt: null })
  @@map("users")
}

model DeviceSession {
  id     String @id @db.Uuid
  userId Int

  deviceName String @db.VarChar
  ip         String @db.VarChar
  jti        String @db.VarChar

  lastActiveAt DateTime @db.Timestamptz
  expiresAt    DateTime @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([userId])
  @@map("device_sessions")
}
