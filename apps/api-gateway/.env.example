# API Gateway environment example.
# Copy this file to `.env` for local development and override values as needed.
# Keep this file free of real credentials, private hosts, and machine-specific secrets.

# HTTP port used by the public API Gateway.
# Format: integer from 0 to 65535.
GATEWAY_PORT=3000

# Public frontend origin used for OAuth redirects.
FRONTEND_URL=https://dev.remark-gram.com

# Comma-separated browser origins allowed to call the Gateway with credentials.
CORS_ALLOWED_ORIGINS=https://dev.remark-gram.com,https://dev.remark-gram.com:3000

# gRPC target address for the files microservice.
# Format: <host>:<port>
# Use localhost when the files service runs on the same machine.
FILES_GRPC_URL=localhost:50051

# gRPC target address for the user-accounts microservice.
USER_ACCOUNTS_GRPC_URL=localhost:50052

# Public key used to verify JWT signatures. Keep the private key only in user-accounts.
JWT_PUBLIC_KEY=change-me
REFRESH_TOKEN_COOKIE_MAX_AGE_MS=1200000

# Destructive testing endpoints. May be enabled in any environment only with a strong secret key.
ENABLE_TESTING_ENDPOINTS=false
TESTING_ENDPOINT_KEY=


# Google reCaptcha rsa
GOOGLE_RECAPTCHA_SECRET_KEY=
