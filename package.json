{
  "name": "remarkgram-backend",
  "type": "module",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "build:api-gateway": "nest build api-gateway",
    "build:files": "nest build files",
    "build:posts": "nest build posts",
    "build:user-accounts": "nest build user-accounts",
    "grpc:generate": "pnpm run grpc:generate:files && pnpm run grpc:generate:user-accounts",
    "grpc:generate:files": "mkdir -p libs/contracts/files-grpc/src/generated && grpc_tools_node_protoc --plugin=protoc-gen-ts_proto=./node_modules/.bin/protoc-gen-ts_proto --ts_proto_out=libs/contracts/files-grpc/src/generated --ts_proto_opt=nestJs=true,esModuleInterop=true,importSuffix=.js --proto_path=libs/contracts/files-grpc/src/proto libs/contracts/files-grpc/src/proto/files.proto",
    "grpc:generate:user-accounts": "mkdir -p libs/contracts/user-accounts-grpc/src/generated && grpc_tools_node_protoc --plugin=protoc-gen-ts_proto=./node_modules/.bin/protoc-gen-ts_proto --ts_proto_out=libs/contracts/user-accounts-grpc/src/generated --ts_proto_opt=nestJs=true,esModuleInterop=true,importSuffix=.js --proto_path=libs/contracts/user-accounts-grpc/src/proto libs/contracts/user-accounts-grpc/src/proto/user-accounts.proto",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "start": "nest start",
    "start:api-gateway": "node dist/apps/api-gateway/apps/api-gateway/src/main.js",
    "start:files": "node dist/apps/files/apps/files/src/main.js",
    "start:posts": "node dist/apps/posts/apps/posts/src/main.js",
    "start:user-accounts": "node dist/apps/user-accounts/apps/user-accounts/src/main.js",
    "start:dev": "nest start --watch",
    "start:dev:api-gateway": "nest start api-gateway --watch",
    "start:dev:files": "nest start files --watch",
    "start:dev:posts": "nest start posts --watch",
    "start:dev:user-accounts": "nest start user-accounts --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/apps/api-gateway/apps/api-gateway/src/main.js",
    "prisma:posts:generate": "prisma generate --config apps/posts/prisma.config.ts",
    "prisma:posts:studio": "prisma studio --config apps/posts/prisma.config.ts",
    "prisma:posts:migrate:dev": "prisma migrate dev --config apps/posts/prisma.config.ts",
    "prisma:posts:migrate:create": "prisma migrate dev --create-only --config apps/posts/prisma.config.ts",
    "prisma:posts:migrate:deploy": "prisma migrate deploy --config apps/posts/prisma.config.ts",
    "prisma:posts:status": "prisma migrate status --config apps/posts/prisma.config.ts",
    "prisma:user-accounts:generate": "prisma generate --config apps/user-accounts/prisma.config.ts",
    "prisma:user-accounts:studio": "prisma studio --config apps/user-accounts/prisma.config.ts",
    "prisma:user-accounts:migrate:dev": "prisma migrate dev --config apps/user-accounts/prisma.config.ts",
    "prisma:user-accounts:migrate:create": "prisma migrate dev --create-only --config apps/user-accounts/prisma.config.ts",
    "prisma:user-accounts:migrate:deploy": "prisma migrate deploy --config apps/user-accounts/prisma.config.ts",
    "prisma:user-accounts:status": "prisma migrate status --config apps/user-accounts/prisma.config.ts",
    "lint": "eslint .",
    "lint:fix": "eslint \"**/*.ts\" --fix",
    "test": "vitest run --exclude \"apps/**/*.e2e-spec.ts\"",
    "test:watch": "vitest --exclude \"apps/**/*.e2e-spec.ts\"",
    "test:cov": "vitest run --exclude \"apps/**/*.e2e-spec.ts\" --coverage",
    "test:debug": "vitest --inspectBrk --run --no-file-parallelism --exclude \"apps/**/*.e2e-spec.ts\"",
    "test:e2e": "vitest run --exclude \"apps/**/*.spec.ts\""
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.14.4",
    "@grpc/proto-loader": "^0.8.1",
    "@nestjs-modules/mailer": "^2.3.7",
    "@nestjs/common": "^11.1.24",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.24",
    "@nestjs/cqrs": "^11.0.3",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/microservices": "^11.1.26",
    "@nestjs/platform-express": "^11.1.24",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcryptjs": "^3.0.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "dotenv": "^17.4.2",
    "nodemailer": "^9.0.3",
    "pg": "^8.21.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@nestjs/cli": "^11.0.21",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.24",
    "@swc/core": "^1.15.40",
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.1",
    "@types/nodemailer": "^8.0.1",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "globals": "^17.6.0",
    "grpc-tools": "^1.13.1",
    "prettier": "^3.8.3",
    "prisma": "^7.8.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "ts-loader": "^9.6.0",
    "ts-node": "^10.9.2",
    "ts-proto": "^2.11.8",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1",
    "unplugin-swc": "^1.5.9",
    "vitest": "^4.1.8"
  },
  "packageManager": "pnpm@11.9.0+sha512.bd682d5d03fe525ef7c9fd6780c6884d1e756ac4c9c9fe00c538782824310dcf90e3ddc4f53835f06dfaebd5085e41855e0bcbb3b60de2ac5bbab89e5036f03b"
}
